{
  "name": "english-language",
  "displayName": "English Language",
  "description": "VS Code support for the English programming language",
  "version": "0.1.0",
  "publisher": "advik-b",
  "packageManager": "bun@1.2.12",
  "repository": {
    "type": "git",
    "url": "https://github.com/Advik-B/english.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:english"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "english",
        "aliases": [
          "English",
          "english"
        ],
        "extensions": [
          ".abc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "english",
        "scopeName": "source.english",
        "path": "./syntaxes/english.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "English Language",
      "properties": {
        "english.languageServer.path": {
          "type": "string",
          "default": "english",
          "description": "Path to the English language binary."
        },
        "english.languageServer.args": {
          "type": "array",
          "default": [
            "lsp"
          ],
          "description": "Arguments passed to the English language server binary.",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "echo 'No extension lint configured'",
    "pretest": "npm run compile",
    "test": "bash -lc 'if command -v xvfb-run >/dev/null 2>&1; then xvfb-run -a node ./out/test/runTest.js; else node ./out/test/runTest.js; fi'",
    "package:vsix": "vsce package --out english-language.vsix"
  },
  "dependencies": {
    "tar": "^7.5.13",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.50",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "glob": "^10.4.5",
    "mocha": "^10.8.2",
    "typescript": "^5.8.3"
  }
}
